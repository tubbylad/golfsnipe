# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Postgres connection string.
# Local dev: run `npm run db:dev` (embedded-postgres) — this URL matches it.
# Production: a Coolify-provisioned Postgres with the same URL contract.
DATABASE_URL=postgresql://brs:brs@localhost:5432/brs

# Credential vault key — 32 random bytes, base64. Generate with:
#   openssl rand -base64 32
BRS_VAULT_KEY=

# Public origin of the app (used for absolute URLs / cookies).
APP_ORIGIN=http://localhost:3000

# Resend API key for transactional email (optional until Phase 6).
RESEND_API_KEY=

# Hetzner SMS sender endpoint + sender id (optional until Phase 6).
SMS_ENDPOINT=
SMS_SENDER=GolfSniper
